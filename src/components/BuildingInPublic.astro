---
import type { RecentCommit } from '../utils/github';

interface Props {
  commits: RecentCommit[];
  fetchedAt: string;
}

const { commits, fetchedAt } = Astro.props;

const fetchedDate = new Date(fetchedAt);
const minutesAgo = Math.max(0, Math.round((Date.now() - fetchedDate.getTime()) / 60000));
const updatedLabel = minutesAgo < 1 ? 'just now' : minutesAgo < 60 ? `${minutesAgo} min ago` : `${Math.round(minutesAgo / 60)}h ago`;
---

<section class="bip">
  <div class="bip-header">
    <div>
      <span class="label">BUILDING IN PUBLIC</span>
    </div>
    <div class="bip-status">
      <span class="status-dot"></span>
      <span class="meta">Updated {updatedLabel}</span>
    </div>
  </div>

  <div class="bip-content">
    <h3 class="bip-heading">Recent code</h3>
    <p class="meta">via GitHub</p>
    <ul class="bip-list">
      {commits.map(commit => (
        <li>
          <span class="bip-dot"></span>
          <div>
            <span class="bip-title">{commit.message}</span>
            <span class="meta">{commit.repo} &middot; {commit.date}</span>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .bip {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 24px;
    margin: 32px 0;
  }
  .bip-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
  }
  .bip-status {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .status-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--teal);
    display: inline-block;
  }
  .bip-heading {
    font-size: 15px;
    font-weight: 500;
    margin-bottom: 2px;
    color: var(--accent-text);
  }
  .bip-list {
    list-style: none;
    margin-top: 16px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .bip-list li {
    display: flex;
    gap: 8px;
    align-items: flex-start;
  }
  .bip-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
    margin-top: 6px;
    background: var(--teal);
  }
  .bip-title {
    display: block;
    font-size: 13px;
    font-weight: 500;
  }
</style>
