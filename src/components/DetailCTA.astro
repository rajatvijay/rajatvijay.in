<aside class="detail-cta">
  <div class="detail-cta-inner">
    <a href="/newsletter" class="detail-cta-link">
      <span class="detail-cta-icon">&#9993;</span>
      <span>Subscribe to the blog</span>
    </a>
    <span class="detail-cta-sep"></span>
    <a href="https://topmate.io/rajatvijay" target="_blank" rel="noopener noreferrer" class="detail-cta-link">
      <span class="detail-cta-icon">&#128172;</span>
      <span>Book a 1:1 AMA</span>
    </a>
  </div>
</aside>

<style>
  .detail-cta {
    margin-top: 48px;
    padding-top: 24px;
    border-top: 1px solid var(--border);
  }
  .detail-cta-inner {
    display: flex;
    align-items: center;
    gap: 24px;
  }
  .detail-cta-link {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    color: var(--text-muted);
    transition: color 0.2s;
  }
  .detail-cta-link:hover {
    color: var(--text-primary);
  }
  .detail-cta-icon {
    font-size: 14px;
  }
  .detail-cta-sep {
    width: 1px;
    height: 16px;
    background: var(--border);
  }
  @media (max-width: 768px) {
    .detail-cta-inner { flex-direction: column; align-items: flex-start; gap: 12px; }
    .detail-cta-sep { display: none; }
  }
</style>
