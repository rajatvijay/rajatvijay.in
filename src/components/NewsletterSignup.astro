---
interface Props {
  variant?: 'inline' | 'full';
}
const { variant = 'inline' } = Astro.props;
const HeadingTag = variant === 'full' ? 'h1' : 'h2';
---

<section class:list={['newsletter', variant]}>
  <div class="newsletter-inner">
    {variant === 'full' && <span class="label accent-text">NEWSLETTER</span>}
    <HeadingTag class="newsletter-title">The Frontend&rarr;AI Weekly</HeadingTag>
    <p class="meta newsletter-desc">
      Weekly essays on building AI products, leading engineering teams,
      and the messy path from frontend to AI leadership.
    </p>
    <form class="newsletter-form" aria-label="Newsletter subscription">
      <div class="newsletter-form-fields">
        <label for={`newsletter-email-${variant}`} class="sr-only">Email address</label>
        <input
          type="email"
          id={`newsletter-email-${variant}`}
          name="email"
          placeholder="your@email.com"
          autocomplete="email"
          required
          aria-describedby={`newsletter-status-${variant}`}
          class="newsletter-input"
        />
        <input type="text" name="hp_zq9k" style="display:none" tabindex="-1" autocomplete="off" aria-hidden="true" />
        <button type="submit" class="btn btn-primary newsletter-btn">Join the weekly</button>
      </div>
      <p class="newsletter-privacy">One email a week. No tricks.</p>
      <div id={`newsletter-status-${variant}`} class="newsletter-status" role="status" aria-live="polite"></div>
    </form>
    <noscript>
      <p class="newsletter-privacy">
        <a href="https://buttondown.com/vijay" class="teal-text">Subscribe on Buttondown</a>
      </p>
    </noscript>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLFormElement>('.newsletter-form').forEach((form) => {
    let submitting = false;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (submitting) return;
      submitting = true;

      const honeypot = form.querySelector<HTMLInputElement>('input[name="hp_zq9k"]');
      if (honeypot && honeypot.value) {
        const status = form.querySelector('.newsletter-status');
        if (status) status.textContent = 'Welcome — check your inbox to confirm.';
        submitting = false;
        return;
      }

      const emailInput = form.querySelector<HTMLInputElement>('input[name="email"]');
      const button = form.querySelector<HTMLButtonElement>('button[type="submit"]');
      const status = form.querySelector<HTMLElement>('.newsletter-status');
      if (!emailInput || !button || !status) {
        console.error('NewsletterSignup: missing DOM elements');
        submitting = false;
        return;
      }

      const email = emailInput.value.trim();
      if (!email) {
        submitting = false;
        return;
      }

      emailInput.disabled = true;
      button.disabled = true;
      button.textContent = 'Joining...';
      status.textContent = '';
      status.classList.remove('newsletter-error');

      let succeeded = false;
      try {
        const controller = new AbortController();
        const timeoutId = setTimeout(() => controller.abort(), 10000);
        const res = await fetch('https://buttondown.com/api/emails/embed-subscribe/vijay', {
          method: 'POST',
          body: new URLSearchParams({ email, embed: '1' }),
          signal: controller.signal,
        });
        clearTimeout(timeoutId);

        if (res.ok) {
          succeeded = true;
          const showSuccess = () => {
            const wrapper = document.createElement('div');
            wrapper.className = 'newsletter-success';
            wrapper.tabIndex = -1;

            const svgNS = 'http://www.w3.org/2000/svg';
            const svg = document.createElementNS(svgNS, 'svg');
            svg.setAttribute('class', 'check-icon');
            svg.setAttribute('width', '28');
            svg.setAttribute('height', '28');
            svg.setAttribute('viewBox', '0 0 24 24');
            svg.setAttribute('fill', 'none');
            svg.setAttribute('stroke', 'currentColor');
            svg.setAttribute('stroke-width', '2');
            svg.setAttribute('stroke-linecap', 'round');
            svg.setAttribute('stroke-linejoin', 'round');
            svg.setAttribute('aria-hidden', 'true');
            const circle = document.createElementNS(svgNS, 'circle');
            circle.setAttribute('cx', '12');
            circle.setAttribute('cy', '12');
            circle.setAttribute('r', '10');
            circle.setAttribute('class', 'check-circle');
            const path = document.createElementNS(svgNS, 'path');
            path.setAttribute('d', 'M8 12l3 3 5-5');
            path.setAttribute('class', 'check-path');
            svg.appendChild(circle);
            svg.appendChild(path);

            const text = document.createElement('span');
            text.textContent = 'Welcome aboard \u2014 check your inbox to confirm.';

            wrapper.appendChild(svg);
            wrapper.appendChild(text);
            wrapper.style.opacity = '0';
            wrapper.style.transition = 'opacity 0.3s ease-in';
            form.replaceChildren(wrapper);
            form.style.opacity = '1';
            requestAnimationFrame(() => {
              wrapper.style.opacity = '1';
              wrapper.focus();
            });
          };
          form.style.transition = 'opacity 0.2s ease-out';
          form.style.opacity = '0';
          form.addEventListener('transitionend', showSuccess, { once: true });
        } else {
          const msg = res.status === 429
            ? 'Too many requests. Please try again later.'
            : 'Something went wrong. Please check your email and try again.';
          status.textContent = msg;
          status.classList.add('newsletter-error');
          emailInput.focus();
        }
      } catch (error) {
        console.error('Newsletter subscription failed:', error);
        const msg = error instanceof DOMException && error.name === 'AbortError'
          ? 'Request timed out. Please try again.'
          : 'Something went wrong. Please try again.';
        status.textContent = msg;
        status.classList.add('newsletter-error');
      } finally {
        if (!succeeded) {
          emailInput.disabled = false;
          button.disabled = false;
          button.textContent = 'Join the weekly';
        }
        submitting = false;
      }
    });
  });
</script>

<style>
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .newsletter {
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 32px;
    margin: 40px 0;
    background: var(--surface);
    animation: fadeInUp 0.4s ease-out both;
  }
  .newsletter.full {
    text-align: center;
    max-width: 560px;
    margin: 0 auto;
    border: none;
    background: transparent;
    padding: 0;
  }
  .newsletter.full .newsletter-title {
    font-size: 32px;
  }
  .newsletter-title {
    font-family: var(--font-serif);
    font-size: 24px;
    font-weight: 400;
    margin: 8px 0;
  }
  .newsletter-desc {
    margin-bottom: 16px;
    max-width: 440px;
  }
  .newsletter.full .newsletter-desc {
    margin-left: auto;
    margin-right: auto;
  }

  /* Form */
  .newsletter-form-fields {
    display: flex;
    gap: 8px;
    align-items: stretch;
  }
  .newsletter.full .newsletter-form-fields {
    justify-content: center;
  }
  .newsletter-input {
    flex: 1;
    max-width: 320px;
    padding: 10px 16px;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--bg);
    color: var(--text-primary);
    font-family: var(--font-sans);
    font-size: 14px;
    min-height: 44px;
  }
  .newsletter-input::placeholder {
    color: var(--text-muted);
  }
  .newsletter-input:focus {
    outline: 2px solid var(--focus-ring);
    outline-offset: 2px;
    border-color: var(--focus-ring);
  }
  .newsletter-input:disabled,
  .newsletter-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }
  .newsletter-btn {
    min-height: 44px;
    min-width: 44px;
    white-space: nowrap;
    transition: background 0.2s, border-color 0.2s, transform 0.1s;
  }
  .newsletter-btn:active:not(:disabled) {
    transform: scale(0.97);
  }
  .newsletter-privacy {
    font-size: 12px;
    color: var(--text-muted);
    margin-top: 8px;
  }
  .newsletter-status {
    margin-top: 8px;
    font-size: 14px;
    min-height: 20px;
  }
  .newsletter-error {
    color: var(--error);
  }
  .newsletter-form :global(.newsletter-success) {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 15px;
    color: var(--teal-text);
    font-weight: 500;
    padding: 8px 0;
  }
  .newsletter.full .newsletter-form :global(.newsletter-success) {
    justify-content: center;
  }
  .newsletter-form :global(.newsletter-success:focus) {
    outline: 2px solid var(--focus-ring);
    outline-offset: 2px;
    border-radius: 4px;
  }
  .newsletter-form :global(.check-icon) {
    flex-shrink: 0;
    color: var(--teal-text);
  }
  .newsletter-form :global(.check-circle) {
    stroke-dasharray: 63;
    stroke-dashoffset: 63;
    animation: draw-circle 0.5s ease-out 0.1s forwards;
  }
  .newsletter-form :global(.check-path) {
    stroke-dasharray: 20;
    stroke-dashoffset: 20;
    animation: draw-check 0.3s ease-out 0.5s forwards;
  }
  @keyframes draw-circle {
    to { stroke-dashoffset: 0; }
  }
  @keyframes draw-check {
    to { stroke-dashoffset: 0; }
  }

  @media (max-width: 480px) {
    .newsletter-form-fields {
      flex-direction: column;
    }
    .newsletter-input {
      max-width: none;
    }
  }
</style>
