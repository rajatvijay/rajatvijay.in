---
interface Props {
  variant?: 'inline' | 'full';
}
const { variant = 'inline' } = Astro.props;
---

<section class:list={['newsletter', variant]}>
  <div class="newsletter-inner">
    {variant === 'full' && <span class="label accent-text">NEWSLETTER</span>}
    <h2 class="newsletter-title">The Frontend→AI Weekly</h2>
    <p class="meta newsletter-desc">
      Weekly essays on building AI products, leading engineering teams,
      and the messy path from frontend to AI leadership.
    </p>
    <form class="newsletter-form" id="newsletter-form">
      <label for="newsletter-email" class="sr-only">Email address</label>
      <input
        type="email"
        id="newsletter-email"
        name="email"
        placeholder="your@email.com"
        required
        autocomplete="email"
        class="newsletter-input"
        aria-describedby="newsletter-note"
      />
      <button type="submit" class="btn-primary btn" id="newsletter-btn">Subscribe</button>
    </form>
    <p class="newsletter-note meta" id="newsletter-note">
      Join 840+ engineering leaders &middot; No spam &middot; Unsubscribe anytime
    </p>
  </div>
</section>

<script>
  document.querySelectorAll('#newsletter-form').forEach(form => {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const btn = form.querySelector('#newsletter-btn');
      if (btn) {
        btn.textContent = 'Coming soon!';
        btn.setAttribute('disabled', 'true');
        setTimeout(() => {
          btn.textContent = 'Subscribe';
          btn.removeAttribute('disabled');
        }, 3000);
      }
    });
  });
</script>

<style>
  .newsletter {
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 32px;
    margin: 40px 0;
    background: var(--surface);
  }
  .newsletter.full {
    border-top: 3px solid var(--accent);
    text-align: center;
    max-width: 560px;
    margin: 40px auto;
  }
  .newsletter-title {
    font-family: var(--font-serif);
    font-size: 24px;
    font-weight: 400;
    margin: 8px 0;
  }
  .newsletter-desc {
    margin-bottom: 16px;
    max-width: 440px;
  }
  .newsletter.full .newsletter-desc {
    margin-left: auto;
    margin-right: auto;
  }
  .newsletter-form {
    display: flex;
    gap: 8px;
    margin-bottom: 12px;
  }
  .newsletter.full .newsletter-form {
    justify-content: center;
  }
  .newsletter-input {
    flex: 1;
    max-width: 280px;
    padding: 10px 14px;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--bg);
    color: var(--text-primary);
    font-size: 14px;
    font-family: var(--font-sans);
  }
  .newsletter-input:focus {
    outline: 2px solid var(--accent);
    outline-offset: -1px;
    border-color: var(--accent);
  }
  .newsletter-note {
    font-size: 12px;
  }
</style>
