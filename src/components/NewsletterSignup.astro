---
interface Props {
  variant?: 'inline' | 'full';
}
const { variant = 'inline' } = Astro.props;
---

<section class:list={['newsletter', variant]}>
  <div class="newsletter-inner">
    {variant === 'full' && <span class="label accent-text">NEWSLETTER</span>}
    <h2 class="newsletter-title">The Frontend→AI Weekly</h2>
    <p class="meta newsletter-desc">
      Weekly essays on building AI products, leading engineering teams,
      and the messy path from frontend to AI leadership.
    </p>
    <p class="newsletter-coming-soon">Newsletter launching soon.</p>
  </div>
</section>

<style>
  .newsletter {
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 32px;
    margin: 40px 0;
    background: var(--surface);
  }
  .newsletter.full {
    border-top: 3px solid var(--accent);
    text-align: center;
    max-width: 560px;
    margin: 40px auto;
  }
  .newsletter-title {
    font-family: var(--font-serif);
    font-size: 24px;
    font-weight: 400;
    margin: 8px 0;
  }
  .newsletter-desc {
    margin-bottom: 12px;
    max-width: 440px;
  }
  .newsletter.full .newsletter-desc {
    margin-left: auto;
    margin-right: auto;
  }
  .newsletter-coming-soon {
    font-size: 13px;
    color: var(--text-muted);
    font-style: italic;
  }
</style>
