---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — Rajat">
  <div class="container four-oh-four">
    <span class="four-number">404</span>
    <h1>This page doesn't exist yet</h1>
    <p class="accent-text tagline">Kind of like my ML degree when I started leading AI.</p>
    <p class="secondary-text">But that worked out fine. Let's get you somewhere useful:</p>
    <div class="four-actions">
      <a href="/writing" class="btn">Read the blog</a>
      <a href="/projects" class="btn">See projects</a>
      <a href="/" class="btn">Go home</a>
    </div>
    <p class="terminal meta">
      <code>$ curl -I rajat.dev/this-page → HTTP/1.1 404 Not Found</code>
    </p>
  </div>
</BaseLayout>

<style>
  .four-oh-four {
    text-align: center;
    padding: 80px 24px;
    max-width: 560px;
    margin: 0 auto;
  }
  .four-number {
    font-size: 120px;
    font-weight: 500;
    color: var(--border);
    line-height: 1;
    display: block;
    margin-bottom: 16px;
  }
  h1 {
    margin-bottom: 8px;
  }
  .tagline {
    font-size: 18px;
    margin-bottom: 8px;
  }
  .four-actions {
    display: flex;
    justify-content: center;
    gap: 12px;
    margin: 32px 0;
  }
  .terminal {
    margin-top: 32px;
  }
  .terminal code {
    background: none;
    font-size: 13px;
    color: var(--text-muted);  /* AAA-safe with updated --text-muted values */
  }
  @media (max-width: 768px) {
    .four-number { font-size: 80px; }
    .four-actions { flex-direction: column; align-items: center; }
  }
</style>
