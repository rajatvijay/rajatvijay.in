---
import BaseLayout from '../layouts/BaseLayout.astro';

const thinkingStack = {
  models: [
    'Composability over configuration',
    'Ship → measure → iterate',
    '70/20/10 capacity splits',
    'Defaults beat options',
    'Optimize for team velocity, not individual output',
  ],
  books: [
    'Thinking in Systems — D. Meadows',
    'Staff Engineer — W. Larson',
    'The Art of Action — S. Bungay',
    'Designing Data Apps — B. Wilke',
    'An Elegant Puzzle — W. Larson',
  ],
  tools: [
    'Claude Code',
    'Linear',
    'Excalidraw',
    'Obsidian',
    'Figma',
  ],
};

const faq = [
  {
    q: "But you're a frontend engineer — how did you end up leading AI?",
    a: "The skills that made me good at React — composability, state management, user empathy — turned out to be the same skills that matter in AI product design. I taught myself enough ML to evaluate approaches and hire well. The rest is product sense and system thinking, which I'd been building for a decade.",
  },
  {
    q: 'Do you still write code?',
    a: "Yes, but differently. I prototype, review PRs, and build internal tools. I don't own production features anymore — that's my team's job. But I stay close enough to the code to make informed architecture decisions and to never lose the empathy for what shipping feels like.",
  },
  {
    q: 'How do you evaluate ML work without an ML background?',
    a: "I ask three questions: What's the baseline? What's the failure mode? What does the user see when it's wrong? I learned enough statistics to understand precision/recall tradeoffs. For everything else, I hired people smarter than me in ML and created an environment where they challenge my assumptions.",
  },
  {
    q: 'What advice would you give someone moving from IC to management?',
    a: "Your job is no longer to be the best engineer in the room. It's to make the room better. The hardest part isn't learning management — it's unlearning the habit of solving problems yourself instead of creating the conditions for your team to solve them.",
  },
  {
    q: 'How do you stay technical as a director?',
    a: "I build side projects (this site, for example). I use Claude Code daily. I do architecture reviews. And I keep one 'hands-on' project per quarter where I write real code, even if it's an internal tool. The moment you stop building, your technical judgment starts decaying.",
  },
];

const principles = [
  {
    title: "I never assign work I haven't done myself",
    detail: "If I'm asking you to set up a monitoring pipeline, I've already set one up at least once to understand the friction.",
  },
  {
    title: "Every 1:1 starts with 'what's blocking you?'",
    detail: "Not status updates. We have Linear for that.",
  },
  {
    title: 'Ship with 80% confidence',
    detail: "The last 20% of certainty costs 80% of the time. Ship, measure, adjust.",
  },
  {
    title: 'The person closest to the problem makes the call',
    detail: "Title doesn't equal context. Engineers decide architecture; PMs decide scope.",
  },
  {
    title: 'Celebrate the assist, not just the goal',
    detail: "The engineer who unblocked three teammates shipped more than the one who closed three tickets.",
  },
];

const diffLines = [
  { type: '-', text: 'Role: Frontend Engineer' },
  { type: '+', text: 'Role: Director of Engineering & AI' },
  { type: '', text: '' },
  { type: '-', text: 'Team: just me and the DOM' },
  { type: '+', text: 'Team: 25 engineers across 4 squads' },
  { type: '', text: '' },
  { type: '-', text: 'Stack: React, TypeScript, CSS' },
  { type: '+', text: 'Stack: React, TypeScript, Python, Claude API, Portkey, Qdrant' },
  { type: '', text: '' },
  { type: '-', text: 'Challenge: pixel-perfect responsive layouts' },
  { type: '+', text: 'Challenge: multi-agent orchestration at enterprise scale' },
  { type: '', text: '' },
  { type: '-', text: 'Metric: Lighthouse score' },
  { type: '+', text: 'Metric: 73% user drop-off → 15% user drop-off' },
];
---

<BaseLayout title="About — Rajat" description="Director of Engineering & AI at Certa. Building AI products and writing about the path from frontend to AI leadership.">
  <div class="container" style="padding-top: 48px;">

    <div class="about-header">
      <div class="avatar-placeholder"></div>
      <div>
        <h1 style="margin-bottom: 4px;">Rajat</h1>
        <p class="secondary-text">
          Director of Engineering & AI at Certa. I build AI products<br />
          and write about the path from frontend to AI leadership.
        </p>
        <div class="social-links">
          <a href="https://twitter.com/rajatvijay" target="_blank" rel="noopener noreferrer" class="teal-text">X / Twitter</a>
          <a href="https://github.com/rajatvijay" target="_blank" rel="noopener noreferrer" class="teal-text">GitHub</a>
          <a href="https://www.linkedin.com/in/rajat-vijay/" target="_blank" rel="noopener noreferrer" class="teal-text">LinkedIn</a>
        </div>
      </div>
    </div>

    <section class="about-section">
      <span class="label accent-text">THE SHORT VERSION</span>
      <div class="about-text">
        <p>I started as a frontend engineer obsessed with React and TypeScript. I realized the most interesting problems were at the intersection of AI and product — so I taught myself enough ML to be dangerous. Now I lead a 25-person team at Certa, shipping AI products to enterprises.</p>
      </div>
    </section>

    <section class="about-section">
      <span class="label accent-text">THE DIFF</span>
      <div class="diff-card surface-card">
        <div class="diff-header">
          <span class="diff-filename">rajat-career.diff</span>
          <span class="diff-stats meta">
            <span class="diff-add">+5</span>
            <span class="diff-del">-5</span>
          </span>
        </div>
        <pre class="diff-content">{diffLines.map(line => (
          <span class:list={['diff-line', { add: line.type === '+', del: line.type === '-', empty: line.type === '' }]}>
            {line.type === '' ? '\n' : `${line.type} ${line.text}\n`}
          </span>
        ))}</pre>
      </div>
    </section>

    <section class="about-section">
      <span class="label accent-text">HOW I THINK</span>
      <div class="thinking-grid">
        <div class="thinking-col surface-card">
          <span class="label">MENTAL MODELS</span>
          <ul class="thinking-list">
            {thinkingStack.models.map(m => <li>{m}</li>)}
          </ul>
        </div>
        <div class="thinking-col surface-card">
          <span class="label">BOOKS THAT SHAPED ME</span>
          <ul class="thinking-list">
            {thinkingStack.books.map(b => <li>{b}</li>)}
          </ul>
        </div>
        <div class="thinking-col surface-card">
          <span class="label">TOOLS I USE DAILY</span>
          <ul class="thinking-list">
            {thinkingStack.tools.map(t => <li>{t}</li>)}
          </ul>
        </div>
      </div>
    </section>

    <section class="about-section">
      <span class="label accent-text">QUESTIONS PEOPLE ASK ME</span>
      <div class="faq-list">
        {faq.map(item => (
          <details class="faq-item">
            <summary class="faq-question">{item.q}</summary>
            <p class="faq-answer">{item.a}</p>
          </details>
        ))}
      </div>
    </section>

    <section class="about-section">
      <span class="label accent-text">HOW I LEAD</span>
      <div class="principles-list">
        {principles.map(p => (
          <div class="principle-item">
            <p class="principle-title">{p.title}</p>
            <p class="principle-detail meta">{p.detail}</p>
          </div>
        ))}
      </div>
    </section>

    <div class="colophon surface-card">
      <span class="label">COLOPHON</span>
      <p class="meta" style="margin-top: 4px;">Built with Astro &middot; Inter + Playfair Display &middot; Vercel &middot; Bangalore</p>
    </div>
  </div>
</BaseLayout>

<style>
  .about-header {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 40px;
  }
  .avatar-placeholder {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: var(--border);
    flex-shrink: 0;
  }
  .social-links {
    display: flex;
    gap: 16px;
    margin-top: 8px;
    font-size: 14px;
  }
  .about-section { margin-bottom: 48px; }
  .about-text {
    margin-top: 12px;
    max-width: 640px;
    line-height: 1.7;
  }

  /* ═══════ Career Diff ═══════ */
  .diff-card {
    margin-top: 12px;
    padding: 0;
    overflow: hidden;
  }
  .diff-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 16px;
    background: var(--border);
    font-family: var(--font-mono);
    font-size: 13px;
  }
  .diff-filename { font-weight: 500; }
  .diff-stats { display: flex; gap: 8px; }
  .diff-add { color: var(--teal-text); }
  .diff-del { color: var(--accent-text); }
  .diff-content {
    padding: 16px;
    margin: 0;
    font-family: var(--font-mono);
    font-size: 13px;
    line-height: 1.8;
    background: var(--surface);
    overflow-x: auto;
    border-radius: 0;
  }
  .diff-line {
    display: block;
  }
  .diff-line.add {
    color: var(--teal-text);
    background: color-mix(in srgb, var(--teal-50) 40%, transparent);
  }
  .diff-line.del {
    color: var(--accent-text);
    background: color-mix(in srgb, var(--coral-50) 40%, transparent);
  }
  .diff-line.empty {
    height: 8px;
  }
  :global(.dark) .diff-line.add {
    background: color-mix(in srgb, var(--teal-900) 40%, transparent);
  }
  :global(.dark) .diff-line.del {
    background: color-mix(in srgb, var(--coral-900) 40%, transparent);
  }

  /* ═══════ Thinking Stack ═══════ */
  .thinking-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    margin-top: 12px;
  }
  .thinking-col { padding: 20px; }
  .thinking-col .label { display: block; margin-bottom: 12px; }
  .thinking-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .thinking-list li {
    font-size: 14px;
    padding-left: 14px;
    position: relative;
    color: var(--text-secondary);
  }
  .thinking-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 8px;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--teal);
  }

  /* ═══════ FAQ ═══════ */
  .faq-list { margin-top: 12px; }
  .faq-item {
    border-bottom: 1px solid var(--border);
  }
  .faq-question {
    padding: 16px 0;
    font-size: 15px;
    font-weight: 500;
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .faq-question::-webkit-details-marker { display: none; }
  .faq-question::after {
    content: '+';
    font-size: 18px;
    color: var(--text-muted);
    flex-shrink: 0;
    margin-left: 16px;
    transition: transform 0.2s;
  }
  .faq-item[open] .faq-question::after {
    content: '−';
    color: var(--accent-text);
  }
  .faq-answer {
    padding: 0 0 16px;
    font-size: 14px;
    line-height: 1.7;
    color: var(--text-secondary);
    max-width: 640px;
  }

  /* ═══════ Principles ═══════ */
  .principles-list { margin-top: 12px; }
  .principle-item {
    padding: 16px 0;
    border-bottom: 1px solid var(--border);
  }
  .principle-title {
    font-size: 15px;
    font-weight: 500;
    margin-bottom: 4px;
  }
  .principle-detail { font-size: 14px; }

  .colophon { margin-top: 48px; }

  @media (max-width: 768px) {
    .about-header { flex-direction: column; text-align: center; }
    .social-links { justify-content: center; }
    .thinking-grid { grid-template-columns: 1fr; }
  }
</style>
