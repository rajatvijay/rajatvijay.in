---
import BaseLayout from '../layouts/BaseLayout.astro';
import schedule from '../data/schedule.json';

const workingOn = [
  { title: 'Studio / Design Agent', desc: 'Natural language → workflow creation', color: 'var(--accent)' },
  { title: 'Core Engine & AI Products', desc: 'LLM-powered risk scoring, semantic search', color: 'var(--teal)' },
  { title: 'Writing & X', desc: 'Weekly essays on AI leadership', color: 'var(--text-muted)' },
];

const beliefs = [
  "You don't need an ML degree to build great AI products.",
  "Frontend thinking transfers directly to AI architecture.",
  "The best AI products disappear into the workflow.",
  "Teams with 70/20/10 capacity splits ship more over time.",
];

const typeColors: Record<string, string> = {
  personal: '#D85A30',
  writing: '#D85A30',
  deepwork: '#1D9E75',
  meetings: '#DC2626',
  strategy: '#0F6E56',
  break: '#B8B5AD',
};

const typeLabels: Record<string, string> = {
  personal: 'Personal / writing',
  writing: 'Personal / writing',
  deepwork: 'Deep work / coding',
  meetings: 'Meetings / calls',
  strategy: '1:1s / strategy',
  break: 'Breaks',
};

function timeToPercent(time: string) {
  const [h, m] = time.split(':').map(Number);
  return ((h - 7) * 60 + m) / (12 * 60) * 100;
}

const hours = Array.from({ length: 13 }, (_, i) => {
  const hour = i + 7;
  const label = hour <= 12 ? `${hour}:00` : `${hour - 12}:00`;
  const left = (i / 12) * 100;
  return { label, left };
});

const scheduleBlocks = schedule.map(block => {
  const left = timeToPercent(block.start);
  const width = timeToPercent(block.end) - left;
  return { ...block, left, width, color: typeColors[block.type] || '#B8B5AD' };
});

const uniqueLegend = Object.entries(typeColors).reduce<{ type: string; label: string; color: string }[]>((acc, [type, color]) => {
  const lbl = typeLabels[type];
  if (lbl && !acc.find(x => x.label === lbl)) acc.push({ type, label: lbl, color });
  return acc;
}, []);
---

<BaseLayout title="About — Rajat" description="Director of Engineering & AI at Certa. Building AI products and writing about the path from frontend to AI leadership.">
  <div class="container" style="padding-top: 48px;">
    <div class="about-header">
      <div class="avatar-placeholder"></div>
      <div>
        <h1 style="margin-bottom: 4px;">Rajat</h1>
        <p class="secondary-text">
          Director of Engineering & AI at Certa. I build AI products<br />
          and write about the path from frontend to AI leadership.
        </p>
        <div class="social-links">
          <a href="https://twitter.com/rajatvijay" target="_blank" rel="noopener noreferrer" class="teal-text">X / Twitter</a>
          <a href="https://github.com/rajatvijay" target="_blank" rel="noopener noreferrer" class="teal-text">GitHub</a>
          <a href="https://www.linkedin.com/in/rajat-vijay/" target="_blank" rel="noopener noreferrer" class="teal-text">LinkedIn</a>
        </div>
      </div>
    </div>

    <section class="about-section">
      <span class="label accent-text">THE SHORT VERSION</span>
      <div class="about-text">
        <p>I started as a frontend engineer obsessed with React and TypeScript.</p>
        <p>I realized the most interesting problems were at the intersection of AI and product — so I taught myself enough ML to be dangerous.</p>
        <p>Now I lead a 25-person team at Certa, shipping AI products to enterprises.</p>
      </div>
    </section>

    <section class="about-section">
      <span class="label accent-text">WHAT I'M WORKING ON NOW</span>
      <div class="working-on-list">
        {workingOn.map(item => (
          <div class="working-on-item surface-card">
            <span class="working-dot" style={`background: ${item.color}`}></span>
            <div>
              <h3 style="font-size: 15px; font-weight: 500;">{item.title}</h3>
              <p class="meta">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="about-section">
      <span class="label accent-text">A TYPICAL DAY AS DIRECTOR OF ENG & AI</span>
      <p class="meta" style="margin: 4px 0 16px;">Focus or hover blocks for details</p>
      <div class="day-timeline" role="list" aria-label="Typical daily schedule">
        <div class="day-hours">
          {hours.map(h => (
            <span class="day-hour" style={`left: ${h.left}%`}>{h.label}</span>
          ))}
        </div>
        <div class="day-blocks">
          {scheduleBlocks.map(block => (
            <div
              class="day-block"
              role="listitem"
              tabindex="0"
              style={`left: ${block.left}%; width: ${block.width}%; background: ${block.color}`}
              aria-label={`${block.start}–${block.end}: ${block.label} — ${block.description}`}
            >
              {block.width > 8 && <span class="day-block-label">{block.label}</span>}
            </div>
          ))}
        </div>
        <div class="day-legend">
          {uniqueLegend.map(item => (
            <span class="legend-item">
              <span class="legend-dot" style={`background: ${item.color}`}></span>
              {item.label}
            </span>
          ))}
        </div>
      </div>

      <div class="time-allocation">
        <span class="label" style="display: block; margin-bottom: 12px;">TIME ALLOCATION</span>
        {[
          { label: 'Deep work / coding', pct: 29, color: '#1D9E75' },
          { label: 'Meetings & calls', pct: 21, color: '#DC2626' },
          { label: 'Strategy & planning', pct: 17, color: '#0F6E56' },
          { label: 'Writing & personal', pct: 21, color: '#D85A30' },
          { label: 'Breaks', pct: 12, color: '#B8B5AD' },
        ].map(item => (
          <div class="alloc-row">
            <span class="alloc-label">{item.label}</span>
            <div class="alloc-bar">
              <div class="alloc-fill" style={`width: ${item.pct}%; background: ${item.color}`}></div>
            </div>
            <span class="meta alloc-pct">{item.pct}%</span>
          </div>
        ))}
      </div>
    </section>

    <section class="about-section">
      <h2 class="label accent-text">THINGS I BELIEVE</h2>
      <ul class="beliefs-list">
        {beliefs.map(b => (
          <li class="belief-item">{b}</li>
        ))}
      </ul>
    </section>

    <div class="colophon surface-card">
      <span class="label">COLOPHON</span>
      <p class="meta" style="margin-top: 4px;">Built with Astro &middot; Inter + Instrument Serif &middot; Vercel &middot; Bangalore</p>
    </div>
  </div>
</BaseLayout>

<style>
  .about-header {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 40px;
  }
  .avatar-placeholder {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: var(--border);
    flex-shrink: 0;
  }
  .social-links {
    display: flex;
    gap: 16px;
    margin-top: 8px;
    font-size: 14px;
  }
  .about-section {
    margin-bottom: 40px;
  }
  .about-text {
    margin-top: 12px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .working-on-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-top: 12px;
  }
  .working-on-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px 20px;
  }
  .working-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .day-timeline {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 20px;
    margin-top: 8px;
    overflow-x: auto;
  }
  .day-hours {
    position: relative;
    height: 20px;
    margin-bottom: 8px;
    min-width: 600px;
  }
  .day-hour {
    position: absolute;
    font-size: 11px;
    color: var(--text-muted);
    transform: translateX(-50%);
  }
  .day-blocks {
    position: relative;
    height: 48px;
    min-width: 600px;
    margin-bottom: 12px;
  }
  .day-block {
    position: absolute;
    top: 0;
    height: 100%;
    border-radius: 6px;
    display: flex;
    align-items: center;
    padding: 0 8px;
    cursor: pointer;
    opacity: 0.85;
    transition: opacity 0.2s, transform 0.2s;
  }
  .day-block:hover {
    opacity: 1;
    transform: scaleY(1.05);
  }
  .day-block-label {
    font-size: 12px;
    color: white;
    font-weight: 500;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .day-legend {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }
  .legend-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    color: var(--text-secondary);
  }
  .legend-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }
  .time-allocation {
    margin-top: 24px;
  }
  .alloc-row {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 8px;
  }
  .alloc-label {
    width: 160px;
    font-size: 14px;
    flex-shrink: 0;
  }
  .alloc-bar {
    flex: 1;
    height: 24px;
    background: var(--border);
    border-radius: 4px;
    overflow: hidden;
  }
  .alloc-fill {
    height: 100%;
    border-radius: 4px;
    transition: width 0.5s;
  }
  .alloc-pct {
    width: 36px;
    text-align: right;
    font-weight: 500;
  }
  .beliefs-list {
    margin-top: 12px;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .belief-item {
    padding: 14px 0;
    border-bottom: 1px solid var(--border);
    font-size: 15px;
  }
  .colophon {
    margin-top: 40px;
  }
  @media (max-width: 768px) {
    .about-header { flex-direction: column; text-align: center; }
    .social-links { justify-content: center; }
    .alloc-label { width: 120px; font-size: 13px; }
  }
</style>
