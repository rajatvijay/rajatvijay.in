---
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
---

<BaseLayout title="The Frontend→AI Weekly — Rajat" description="Weekly essays on building AI products, leading engineering teams, and the messy path from frontend to AI leadership.">
  <div class="container" style="padding-top: 48px; padding-bottom: 80px;">
    <NewsletterSignup variant="full" />

    <div class="newsletter-body">
      <section class="newsletter-note" data-reveal>
        <h2>Why I write</h2>
        <p>
          I went from writing React components to leading a 50+ person AI engineering team.
          The path was messy, undocumented, and full of decisions I had to figure out alone.
          This newsletter is the guide I wish existed — honest essays about building AI products,
          leading engineering teams, and navigating the shift from IC to leadership.
        </p>
      </section>

      <div class="newsletter-archive">
        <a href="https://buttondown.com/rajatvijay/archive/" target="_blank" rel="noopener noreferrer">
          Read past issues on Buttondown &rarr;
        </a>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .newsletter-body {
    max-width: 560px;
    margin: 0 auto;
  }
  .newsletter-note {
    padding: 32px 0 24px;
  }
  .newsletter-note h2 {
    font-size: 0.9375rem;
    font-weight: 500;
    margin-bottom: 12px;
  }
  .newsletter-note p {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--text-secondary);
  }
  .newsletter-expect {
    padding: 24px 0;
    border-top: 1px solid var(--border);
  }
  .newsletter-expect h2 {
    font-size: 0.9375rem;
    font-weight: 500;
    margin-bottom: 16px;
  }
  .expect-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }
  .expect-item p {
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--text-secondary);
    margin-top: 4px;
  }
  .expect-item strong {
    display: block;
    font-size: 0.9375rem;
    font-weight: 500;
    margin-top: 4px;
  }
  .expect-label {
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--accent-text);
  }
  .newsletter-archive {
    padding: 24px 0;
    border-top: 1px solid var(--border);
    font-size: 0.875rem;
  }
  @media (max-width: 600px) {
    .expect-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
