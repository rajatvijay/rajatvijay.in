---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allProducts = await getCollection('products');

const typeLabels: Record<string, string> = {
  web: 'Web App',
  mobile: 'Mobile',
  oss: 'Open Source',
  template: 'Template',
  download: 'Download',
};
---

<BaseLayout title="Products — Rajat" description="Tools, apps, and projects I've built that you can use.">
  <div class="container" style="padding-top: 48px;">
    <h1>Products</h1>
    <p class="secondary-text" style="margin: 8px 0 40px;">
      Things I've built that you can use — apps, tools, and hosted services.
    </p>

    <div class="items-grid">
      {allProducts.map(product => (
        <a href={`/products/${product.id}`} class="item-card surface-card">
          <div class="item-top">
            <h2 class="item-title">{product.data.title}</h2>
            {product.data.status !== 'live' && (
              <span class:list={['status-badge', product.data.status]}>
                {product.data.status === 'beta' ? 'Beta' : 'Coming soon'}
              </span>
            )}
          </div>
          <p class="item-desc">{product.data.tagline}</p>
          <span class="pill pill-teal">{typeLabels[product.data.type]}</span>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .items-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  .item-card {
    display: block;
    color: var(--text-primary);
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .item-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(0,0,0,0.08);
    color: var(--text-primary);
  }
  .item-card:hover .item-title {
    color: var(--accent-text);
  }
  .item-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 4px;
  }
  .item-title {
    font-size: 18px;
    font-weight: 500;
    transition: color 0.2s;
  }
  .item-desc {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.5;
    margin-bottom: 12px;
  }
  @media (max-width: 768px) {
    .items-grid { grid-template-columns: 1fr; }
  }
</style>
