---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allProducts = await getCollection('products');

const typeLabels: Record<string, string> = {
  web: 'Web App',
  mobile: 'Mobile',
  oss: 'Open Source',
  template: 'Template',
  download: 'Download',
};
---

<BaseLayout title="Products — Rajat" description="Tools, apps, and projects I've built that you can use.">
  <div class="container" style="padding-top: 48px;">
    <h1>Products</h1>
    <p class="secondary-text" style="margin: 8px 0 40px;">
      Things I've built that you can use — apps, tools, and hosted services.
    </p>

    {allProducts.length > 0 ? (
      <div class="items-grid">
        {allProducts.map(product => (
          <a href={`/products/${product.id}`} class="item-card surface-card">
            <div class="item-top">
              <h2 class="item-title">{product.data.title}</h2>
              {product.data.status !== 'live' && (
                <span class:list={['status-badge', product.data.status]}>
                  {product.data.status === 'beta' ? 'Beta' : 'Coming soon'}
                </span>
              )}
            </div>
            <p class="item-desc">{product.data.tagline}</p>
            <span class="pill pill-teal">{typeLabels[product.data.type]}</span>
          </a>
        ))}
      </div>
    ) : (
      <p class="secondary-text">No products yet. Check back soon.</p>
    )}
  </div>
</BaseLayout>

<style>
  .item-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 4px;
  }
</style>
