---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(project => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const data = project.data;
---

<BaseLayout title={`${data.title} — Rajat`} description={data.subtitle}>
  <div class="container" style="padding-top: 40px;">
    <a href="/projects" class="back-link meta">← All projects</a>

    <div class="project-header">
      <div class="project-icon" style={`background: ${data.color}`}></div>
      <div>
        <h1 style="margin-bottom: 4px;">{data.title}</h1>
        <p class="secondary-text">{data.subtitle}</p>
      </div>
    </div>

    <div class="tech-row">
      {data.techStack.map(tech => (
        <span class="tech-pill">{tech}</span>
      ))}
    </div>

    <div class="impact-grid">
      {data.impact.map(item => (
        <div class="impact-card surface-card">
          <span class="impact-metric accent-text">{item.metric}</span>
          <span class="meta">{item.label}</span>
        </div>
      ))}
    </div>

    <hr class="divider" />

    <div class="prose">
      <Content />
    </div>
  </div>
</BaseLayout>

<style>
  .back-link { color: var(--text-secondary); }
  .back-link:hover { color: var(--text-primary); }
  .project-header {
    display: flex;
    align-items: center;
    gap: 16px;
    margin: 24px 0;
  }
  .project-icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    flex-shrink: 0;
  }
  .tech-row {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 24px;
  }
  .impact-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
    margin-bottom: 32px;
  }
  .impact-card {
    text-align: center;
    padding: 24px;
  }
  .impact-metric {
    display: block;
    font-size: 32px;
    font-weight: 500;
    letter-spacing: -0.5px;
    margin-bottom: 4px;
  }
  .divider {
    border: none;
    border-top: 1px solid var(--border);
    margin: 0 0 32px;
  }
  .prose {
    line-height: 1.7;
    max-width: 720px;
  }

  /* H2 — section labels in coral uppercase, like the rest of the site */
  .prose :global(h2) {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--accent-text);
    margin-top: 48px;
    margin-bottom: 12px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--border);
  }
  .prose :global(h2:first-child) {
    margin-top: 0;
  }

  /* H3 — bold inline headings for key points */
  .prose :global(h3) {
    margin-top: 28px;
    margin-bottom: 8px;
    font-size: 16px;
  }

  .prose :global(p) {
    margin-bottom: 16px;
    color: var(--text-secondary);
  }

  /* Lists — teal bullet markers */
  .prose :global(ul), .prose :global(ol) {
    margin-bottom: 16px;
    padding-left: 20px;
  }
  .prose :global(ul) {
    list-style: none;
  }
  .prose :global(ul li) {
    position: relative;
    padding-left: 16px;
    margin-bottom: 8px;
    color: var(--text-secondary);
  }
  .prose :global(ul li::before) {
    content: '';
    position: absolute;
    left: 0;
    top: 10px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--teal);
  }
  .prose :global(ol li) {
    margin-bottom: 8px;
    color: var(--text-secondary);
  }

  /* Strong text — primary color so it pops from secondary body */
  .prose :global(strong) {
    color: var(--text-primary);
    font-weight: 500;
  }

  /* Blockquotes — coral left border callout */
  .prose :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding: 16px 20px;
    background: var(--surface);
    border-radius: 0 8px 8px 0;
    color: var(--text-secondary);
    margin: 24px 0;
  }
  .prose :global(blockquote p) {
    margin-bottom: 0;
  }

  /* Code blocks */
  .prose :global(pre) {
    margin: 24px 0;
  }
  @media (max-width: 768px) {
    .impact-grid { grid-template-columns: 1fr; }
  }
</style>
