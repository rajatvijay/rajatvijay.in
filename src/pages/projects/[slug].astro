---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DetailCTA from '../../components/DetailCTA.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(project => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const data = project.data;
---

<BaseLayout title={`${data.title} — Rajat`} description={data.subtitle}>
  <div class="container page-top-sm">
    <a href="/projects" class="back-link meta">← All projects</a>

    <div class="project-header">
      <div class="project-icon" style={`background: ${data.color}`}></div>
      <div>
        <h1 class="project-title">{data.title}</h1>
        <p class="secondary-text">{data.subtitle}</p>
      </div>
    </div>

    <div class="tech-row">
      {data.techStack.map(tech => (
        <span class="tech-pill">{tech}</span>
      ))}
    </div>

    <div class="impact-grid" data-reveal-stagger>
      {data.impact.map(item => (
        <div class="impact-card surface-card">
          <span class="impact-metric accent-text">{item.metric}</span>
          <span class="meta">{item.label}</span>
        </div>
      ))}
    </div>

    <hr class="divider" />

    <div class="prose">
      <Content />
    </div>

    <DetailCTA />
  </div>
</BaseLayout>

<style>
  .project-title {
    margin-bottom: 4px;
  }
  .project-header {
    display: flex;
    align-items: center;
    gap: 16px;
    margin: 24px 0;
  }
  .project-icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    flex-shrink: 0;
  }
  .tech-row {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 24px;
  }
  .impact-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
    margin-bottom: 32px;
  }
  .impact-card {
    text-align: center;
    padding: 24px;
  }
  .impact-metric {
    display: block;
    font-size: 32px;
    font-weight: 500;
    letter-spacing: -0.5px;
    margin-bottom: 4px;
  }
  @media (max-width: 768px) {
    .impact-grid { grid-template-columns: 1fr; }
  }
</style>
