---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
---

<BaseLayout title="Projects — Rajat" description="Selected projects and case studies from building AI products at enterprise scale.">
  <div class="container" style="padding-top: 48px;">
    <h1>Projects</h1>
    <p class="secondary-text" style="margin: 8px 0 40px;">
      Selected projects and case studies from building AI products at enterprise scale.
    </p>

    <div class="projects-grid">
      {allProjects.map(project => (
        <a href={`/projects/${project.id}`} class="project-item surface-card">
          <div class="project-icon" style={`background: ${project.data.color}`}></div>
          <div>
            <h2 style="font-size: 20px; margin-bottom: 4px;">{project.data.title}</h2>
            <p class="meta">{project.data.subtitle}</p>
          </div>
          <div class="project-tech">
            {project.data.techStack.map(tech => (
              <span class="tech-pill">{tech}</span>
            ))}
          </div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .projects-grid {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .project-item {
    display: block;
    color: var(--text-primary);
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .project-item:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(0,0,0,0.08);
    color: var(--text-primary);
  }
  .project-icon {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    margin-bottom: 16px;
  }
  .project-tech {
    margin-top: 12px;
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
</style>
