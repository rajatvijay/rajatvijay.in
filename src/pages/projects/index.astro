---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
---

<BaseLayout title="Projects — Rajat" description="Open source projects and case studies from building AI products at enterprise scale.">
  <div class="container" style="padding-top: 48px;">
    <h1>Projects</h1>
    <p class="secondary-text" style="margin: 8px 0 40px;">
      Open source work and case studies from building AI products at enterprise scale.
    </p>

    <div class="items-grid">
      {allProjects.map(project => (
        <a href={`/projects/${project.id}`} class="item-card surface-card">
          <h2 class="item-title">{project.data.title}</h2>
          <p class="item-desc">{project.data.subtitle}</p>
          <div class="item-tags">
            {project.data.techStack.map(tech => (
              <span class="tech-pill">{tech}</span>
            ))}
          </div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .items-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  .item-card {
    display: block;
    color: var(--text-primary);
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .item-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(0,0,0,0.08);
    color: var(--text-primary);
  }
  .item-card:hover .item-title {
    color: var(--accent-text);
  }
  .item-title {
    font-size: 18px;
    font-weight: 500;
    margin-bottom: 4px;
    transition: color 0.2s;
  }
  .item-desc {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.5;
    margin-bottom: 12px;
  }
  .item-tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }
  @media (max-width: 768px) {
    .items-grid { grid-template-columns: 1fr; }
  }
</style>
