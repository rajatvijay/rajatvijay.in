---
import BaseLayout from '../layouts/BaseLayout.astro';
import readingData from '../data/reading.json';

const hexRegex = /^#[0-9A-Fa-f]{6}$/;
const books = readingData
  .map(book => ({
    ...book,
    color: hexRegex.test(book.color) ? book.color : '#6B6860',
  }))
  .sort((a, b) => a.order - b.order);
---

<BaseLayout title="Reading — Rajat" description="Books I'm currently reading or recently finished, with one-line takes.">
  <div class="container" style="padding-top: 48px;">
    <h1>Reading</h1>
    <p class="secondary-text" style="margin: 8px 0 40px;">
      Books I'm reading or recently finished. Updated monthly.
    </p>

    <div class="book-list">
      {books.map(book => (
        <div class="book-row surface-card">
          <div class="book-cover">
            {book.cover ? (
              <img src={book.cover} alt={`Cover of ${book.title}`} loading="lazy" width="64" height="96" />
            ) : (
              <div class="cover-placeholder" style={`background: ${book.color}`}></div>
            )}
          </div>
          <div class="book-info">
            <div class="book-header">
              <h2 class="book-title">{book.title}</h2>
              <span class:list={['book-status', book.status === 'Reading' ? 'reading' : 'finished']}>
                {book.status}
              </span>
            </div>
            <p class="meta">{book.author}</p>
            <p class="book-take">{book.quickTake}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .book-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .book-row {
    display: flex;
    gap: 20px;
    align-items: center;
    padding: 16px 20px;
  }
  .book-cover {
    width: 64px;
    height: 96px;
    flex-shrink: 0;
    border-radius: 4px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
  }
  .book-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .cover-placeholder {
    width: 100%;
    height: 100%;
  }
  .book-info { flex: 1; }
  .book-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 4px;
  }
  .book-title {
    font-size: 16px;
    font-weight: 500;
  }
  .book-status {
    font-size: 11px;
    font-weight: 500;
    padding: 2px 8px;
    border-radius: 4px;
    flex-shrink: 0;
  }
  .book-status.reading {
    background: var(--teal-50);
    color: var(--teal-800);
  }
  .book-status.finished {
    background: var(--neutral-200);
    color: var(--neutral-800);  /* AAA: #3D3B36 on #E8E6E1 = 8.97:1 */
  }
  :global(.dark) .book-status.reading {
    background: var(--teal-900);
    color: #78D4B5;             /* AAA: 7.75:1 on #04342C */
  }
  :global(.dark) .book-status.finished {
    background: var(--neutral-800);
    color: #D5D3CD;             /* AAA: 7.47:1 on #3D3B36 */
  }
  .book-take {
    font-size: 14px;
    color: var(--text-secondary);
    margin-top: 6px;
  }
  @media (max-width: 768px) {
    .book-cover {
      width: 48px;
      height: 72px;
    }
  }
</style>
