---
import BaseLayout from '../layouts/BaseLayout.astro';
import talksData from '../data/talks.json';

const featured = talksData.find(t => t.featured);
const allTalks = talksData.filter(t => !t.featured);
---

<BaseLayout title="Speaking & Talks — Rajat" description="Conference talks, podcast appearances, and internal presentations I can share.">
  <div class="container content-width" style="padding-top: 48px;">
    <h1>Speaking & Talks</h1>
    <p class="secondary-text" style="margin: 8px 0 40px;">
      Conference talks, podcast appearances, and internal presentations I can share.
    </p>

    {featured && (
      <div class="featured-talk surface-card">
        <div class="featured-grid">
          <div class="video-placeholder">
            <div class="play-btn">&#9654;</div>
          </div>
          <div class="featured-info">
            <span class="label accent-text">FEATURED TALK</span>
            <h2 style="margin: 8px 0 4px;">{featured.title}</h2>
            <p class="meta">{featured.event} &middot; {featured.date} &middot; {featured.duration}</p>
            {featured.timestamps && (
              <div class="timestamps">
                <span class="label teal-text" style="margin-top: 16px; display: block;">JUMP TO:</span>
                {featured.timestamps.map(ts => (
                  <p class="timestamp-item">
                    <code>{ts.time}</code>
                    <span>{ts.label}</span>
                  </p>
                ))}
              </div>
            )}
          </div>
        </div>
      </div>
    )}

    <section style="margin-top: 40px;">
      <span class="label" style="display: block; margin-bottom: 16px;">ALL TALKS</span>
      <div class="talks-list">
        {allTalks.map(talk => (
          <div class="talk-item">
            <div>
              <h3 style="font-size: 16px; font-weight: 500;">{talk.title}</h3>
              <p class="meta">{talk.event} &middot; {talk.date} &middot; {talk.duration}</p>
            </div>
            <div class="talk-actions">
              {talk.hasVideo && talk.hasSlides ? (
                <span class="teal-text talk-action-link">Video + Slides</span>
              ) : talk.hasVideo ? (
                <span class="teal-text talk-action-link">Video</span>
              ) : talk.hasSlides ? (
                <span class="teal-text talk-action-link">Slides</span>
              ) : null}
            </div>
          </div>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .featured-talk {
    border-left: 3px solid var(--accent);
    overflow: hidden;
  }
  .featured-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    overflow: hidden;
  }
  .video-placeholder {
    background: var(--neutral-900);
    border-radius: 8px;
    aspect-ratio: 16/9;
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 0;
  }
  .featured-info {
    min-width: 0;
  }
  .featured-info h2 {
    word-wrap: break-word;
  }
  .play-btn {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: rgba(255,255,255,0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 18px;
  }
  .timestamps {
    margin-top: 8px;
  }
  .timestamp-item {
    display: flex;
    gap: 12px;
    align-items: center;
    font-size: 14px;
    margin-top: 4px;
  }
  .talks-list {
    display: flex;
    flex-direction: column;
  }
  .talk-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 0;
    border-bottom: 1px solid var(--border);
  }
  .talk-actions {
    display: flex;
    gap: 12px;
  }
  @media (max-width: 768px) {
    .featured-grid { grid-template-columns: 1fr; }
  }
</style>
