---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allTalks = (await getCollection('talks')).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const featured = allTalks.find(t => t.data.featured);
const rest = allTalks.filter(t => !t.data.featured);
---

<BaseLayout title="Speaking & Talks — Rajat" description="Conference talks, podcast appearances, and internal presentations.">
  <div class="container" style="padding-top: 48px;">
    <h1>Speaking & Talks</h1>
    <p class="secondary-text" style="margin: 8px 0 40px;">
      Conference talks, podcast appearances, and internal presentations I can share.
    </p>

    {featured && (
      <a href={`/talks/${featured.id}`} class="featured-talk surface-card">
        <div class="featured-grid">
          <div class="video-thumb">
            {featured.data.youtubeId ? (
              <img
                src={`https://img.youtube.com/vi/${featured.data.youtubeId}/maxresdefault.jpg`}
                alt={`Thumbnail for ${featured.data.title}`}
                loading="eager"
              />
            ) : (
              <div class="thumb-placeholder"></div>
            )}
            <div class="play-btn">&#9654;</div>
          </div>
          <div class="featured-info">
            <span class="label accent-text">FEATURED TALK</span>
            <h2>{featured.data.title}</h2>
            <p class="meta">{featured.data.event} &middot; {featured.data.date.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })} &middot; {featured.data.duration}</p>
            <p class="featured-desc">{featured.data.description}</p>
          </div>
        </div>
      </a>
    )}

    <section style="margin-top: 48px;">
      <span class="label" style="display: block; margin-bottom: 16px;">ALL TALKS</span>
      <div class="talks-list">
        {rest.map(talk => (
          <a href={`/talks/${talk.id}`} class="talk-item">
            <div class="talk-info">
              <h3>{talk.data.title}</h3>
              <p class="meta">{talk.data.event} &middot; {talk.data.date.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })} &middot; {talk.data.duration}</p>
            </div>
            <div class="talk-tags">
              {talk.data.youtubeId && <span class="pill pill-teal">Video</span>}
              {talk.data.slidesUrl && <span class="pill pill-coral">Slides</span>}
            </div>
          </a>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .featured-talk {
    display: block;
    border-left: 3px solid var(--accent);
    overflow: hidden;
    color: var(--text-primary);
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .featured-talk:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(0,0,0,0.08);
    color: var(--text-primary);
  }
  .featured-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }
  .video-thumb {
    position: relative;
    border-radius: 8px;
    overflow: hidden;
    aspect-ratio: 16/9;
    background: var(--neutral-900);
  }
  .video-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .thumb-placeholder {
    width: 100%;
    height: 100%;
    background: var(--neutral-800);
  }
  .play-btn {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.6);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 20px;
    transition: background 0.2s, transform 0.2s;
  }
  .featured-talk:hover .play-btn {
    background: var(--accent);
    transform: translate(-50%, -50%) scale(1.1);
  }
  .featured-info {
    min-width: 0;
  }
  .featured-info h2 {
    font-size: 22px;
    margin: 8px 0 4px;
    word-wrap: break-word;
  }
  .featured-desc {
    font-size: 14px;
    color: var(--text-secondary);
    margin-top: 12px;
    line-height: 1.6;
  }
  .talks-list {
    display: flex;
    flex-direction: column;
  }
  .talk-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 0;
    border-bottom: 1px solid var(--border);
    color: var(--text-primary);
    transition: color 0.2s;
  }
  .talk-item:hover {
    color: var(--text-primary);
  }
  .talk-item:hover h3 {
    color: var(--accent-text);
  }
  .talk-info h3 {
    font-size: 16px;
    font-weight: 500;
    margin-bottom: 4px;
    transition: color 0.2s;
  }
  .talk-tags {
    display: flex;
    gap: 8px;
    flex-shrink: 0;
  }
  @media (max-width: 768px) {
    .featured-grid { grid-template-columns: 1fr; }
    .talk-item { flex-direction: column; align-items: flex-start; gap: 8px; }
  }
</style>
