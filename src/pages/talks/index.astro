---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allTalks = (await getCollection('talks')).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const featured = allTalks.find(t => t.data.featured);
const rest = allTalks.filter(t => !t.data.featured);
---

<BaseLayout title="Speaking & Talks — Rajat" description="Conference talks, podcast appearances, and internal presentations.">
  <Fragment slot="head">
    <link rel="preconnect" href="https://www.youtube-nocookie.com" />
  </Fragment>
  <div class="container page-top">
    <h1>Speaking & Talks</h1>
    <p class="secondary-text page-desc">
      Conference talks, podcast appearances, and internal presentations I can share.
    </p>

    {featured && (
      <div class="featured-talk surface-card">
        <div class="featured-grid">
          <div class="featured-video">
            {featured.data.youtubeId ? (
              <iframe
                src={`https://www.youtube-nocookie.com/embed/${featured.data.youtubeId}?rel=0&modestbranding=1`}
                title={featured.data.title}
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
                loading="lazy"
                sandbox="allow-scripts allow-same-origin allow-presentation"
              ></iframe>
            ) : (
              <div class="thumb-placeholder"></div>
            )}
          </div>
          <div class="featured-info">
            <span class="label accent-text">FEATURED TALK</span>
            <a href={`/talks/${featured.id}`} class="featured-title-link">
              <h2>{featured.data.title}</h2>
            </a>
            <p class="meta">{featured.data.event} &middot; {featured.data.date.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })} &middot; {featured.data.duration}</p>
            <p class="featured-desc">{featured.data.description}</p>
            <div class="featured-actions">
              <a href={`/talks/${featured.id}`} class="teal-text">Read more →</a>
              {featured.data.slidesUrl && <a href={featured.data.slidesUrl} target="_blank" rel="noopener noreferrer" class="teal-text">View slides</a>}
            </div>
          </div>
        </div>
      </div>
    )}

    <section class="all-talks-section">
      <span class="label all-talks-label">ALL TALKS</span>
      <div class="talks-list">
        {rest.map(talk => (
          <a href={`/talks/${talk.id}`} class="talk-item">
            <div class="talk-info">
              <h3>{talk.data.title}</h3>
              <p class="meta">{talk.data.event} &middot; {talk.data.date.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })} &middot; {talk.data.duration}</p>
            </div>
            <div class="talk-tags">
              {talk.data.youtubeId && <span class="pill pill-teal">Video</span>}
              {talk.data.slidesUrl && <span class="pill pill-coral">Slides</span>}
              {!talk.data.youtubeId && !talk.data.slidesUrl && <span class="pill pill-neutral">Notes</span>}
            </div>
          </a>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .all-talks-section {
    margin-top: 48px;
  }
  .all-talks-label {
    display: block;
    margin-bottom: 16px;
  }
  .featured-talk {
    border-left: 3px solid var(--accent);
    overflow: hidden;
  }
  .featured-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }
  .featured-video {
    position: relative;
    padding-bottom: 56.25%;
    border-radius: 8px;
    overflow: hidden;
    background: var(--neutral-900);
  }
  .featured-video iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
  .thumb-placeholder {
    position: absolute;
    inset: 0;
    background: var(--neutral-800);
  }
  .featured-info {
    min-width: 0;
  }
  .featured-title-link {
    color: var(--text-primary);
    text-decoration: none;
  }
  .featured-title-link:hover h2 {
    color: var(--accent-text);
  }
  .featured-info h2 {
    font-size: 22px;
    margin: 8px 0 4px;
    word-wrap: break-word;
    transition: color 0.2s;
  }
  .featured-desc {
    font-size: 14px;
    color: var(--text-secondary);
    margin-top: 12px;
    line-height: 1.6;
  }
  .featured-actions {
    display: flex;
    gap: 16px;
    margin-top: 16px;
    font-size: 14px;
  }
  .talks-list {
    display: flex;
    flex-direction: column;
  }
  .talk-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 0;
    border-bottom: 1px solid var(--border);
    color: var(--text-primary);
    transition: color 0.2s;
  }
  .talk-item:hover {
    color: var(--text-primary);
  }
  .talk-item:hover h3 {
    color: var(--accent-text);
  }
  .talk-info h3 {
    font-size: 16px;
    font-weight: 500;
    margin-bottom: 4px;
    transition: color 0.2s;
  }
  .talk-tags {
    display: flex;
    gap: 8px;
    flex-shrink: 0;
  }
  @media (max-width: 768px) {
    .featured-grid { grid-template-columns: 1fr; }
    .talk-item { flex-direction: column; align-items: flex-start; gap: 8px; }
  }
</style>
