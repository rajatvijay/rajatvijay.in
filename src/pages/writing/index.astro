---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getSortedPosts } from '../../utils/posts';
import { formatDateMedium } from '../../utils/formatDate';

const allPosts = await getSortedPosts();
const allTags = [...new Set(allPosts.flatMap(p => p.data.tags))];
---

<BaseLayout title="Writing — Rajat" description="Essays on building AI products, leading engineering teams, and the path from frontend to AI leadership.">
  <div class="container" style="padding-top: 48px;">
    <h1>Writing</h1>
    <p class="secondary-text" style="margin: 8px 0 32px;">
      Essays on building AI products, leading engineering teams, and the path from frontend to AI leadership.
    </p>

    <div class="tags-row" role="list" aria-label="Filter by tag">
      {allTags.map(tag => (
        <a href={`/writing/tag/${tag}`} class="pill pill-coral" role="listitem">{tag}</a>
      ))}
    </div>

    <ul class="writing-list">
      {allPosts.map(post => (
        <li class="writing-item">
          <a href={`/writing/${post.id}`} class="writing-link">
            <div class="writing-meta">
              <time class="meta" datetime={post.data.date.toISOString()}>{formatDateMedium(post.data.date)}</time>
              <span class="meta">{post.data.readTime} min read</span>
            </div>
            <h2 class="writing-title">{post.data.title}</h2>
            <p class="writing-desc secondary-text">{post.data.description}</p>
            <div class="writing-tags">
              {post.data.tags.map(tag => (
                <a href={`/writing/tag/${tag}`} class="pill pill-teal" style="font-size: 12px; padding: 2px 8px;" onclick="event.stopPropagation();">{tag}</a>
              ))}
            </div>
          </a>
        </li>
      ))}
    </ul>

    {allPosts.length > 0 ? (
      <div class="reading-stats surface-card" style="text-align: center; margin-top: 40px;">
        <p class="meta">You've read through all {allPosts.length} posts</p>
      </div>
    ) : (
      <p class="secondary-text" style="text-align: center; margin-top: 40px;">No posts yet. Check back soon.</p>
    )}
  </div>
</BaseLayout>

<style>
  .tags-row {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 32px;
  }
  .writing-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .writing-item {
    border-bottom: 1px solid var(--border);
  }
  .writing-link {
    display: block;
    padding: 24px 0;
    color: var(--text-primary);
  }
  .writing-link:hover { color: var(--text-primary); }
  .writing-link:hover .writing-title { color: var(--accent); }
  .writing-meta {
    display: flex;
    gap: 16px;
    margin-bottom: 6px;
  }
  .writing-title {
    font-size: 20px;
    font-weight: 500;
    margin-bottom: 6px;
    transition: color 0.2s;
  }
  .writing-desc {
    font-size: 15px;
    margin-bottom: 8px;
    line-height: 1.5;
  }
  .writing-tags {
    display: flex;
    gap: 6px;
  }
</style>
