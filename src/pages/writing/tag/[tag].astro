---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getSortedPosts } from '../../../utils/posts';
import { formatDateMedium } from '../../../utils/formatDate';

export async function getStaticPaths() {
  const posts = await getSortedPosts();
  const tags = [...new Set(posts.flatMap(p => p.data.tags))];
  return tags.map(tag => ({
    params: { tag },
    props: { tag, posts: posts.filter(p => p.data.tags.includes(tag)) },
  }));
}

const { tag, posts } = Astro.props;
---

<BaseLayout title={`${tag} — Writing — Rajat`} description={`Posts tagged "${tag}" on building AI products, leading engineering teams, and the path from frontend to AI leadership.`}>
  <div class="container page-top">
    <a href="/writing" class="back-link meta">← All writing</a>
    <h1 class="tag-heading">Tagged: {tag}</h1>
    <p class="secondary-text page-desc">
      {posts.length} post{posts.length !== 1 ? 's' : ''}
    </p>

    <ul class="writing-list">
      {posts.map(post => (
        <li class="writing-item">
          <a href={`/writing/${post.id}`} class="writing-link">
            <div class="writing-meta">
              <time class="meta" datetime={post.data.date.toISOString()}>{formatDateMedium(post.data.date)}</time>
              <span class="meta">{post.data.readTime} min read</span>
            </div>
            <h2 class="writing-title">{post.data.title}</h2>
            <p class="writing-desc secondary-text">{post.data.description}</p>
          </a>
        </li>
      ))}
    </ul>
  </div>
</BaseLayout>

<style>
  .tag-heading {
    margin-top: 16px;
  }
</style>
